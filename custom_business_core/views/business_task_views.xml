<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree View -->
        <record id="view_business_task_tree" model="ir.ui.view">
            <name>business.task.tree</name>
            <model>business.task</model>
            <arch type="xml">
                <tree string="Business Tasks">
                    <field name="name"/>
                    <field name="date_deadline"/>
                    <field name="priority" widget="priority"/>
                    <field name="kanban_state" widget="state_selection"/>
                </tree>
            </arch>
        </record>

        <!-- Form View -->
        <record id="view_business_task_form" model="ir.ui.view">
            <name>business.task.form</name>
            <model>business.task</model>
            <arch type="xml">
                <form string="Business Task">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" string="Task Title"/>
                            <h1>
                                <field name="name" placeholder="e.g. Core System Integration"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date_deadline"/>
                                <field name="priority" widget="priority"/>
                            </group>
                            <group>
                                <field name="kanban_state" widget="radio" options="{'horizontal': true}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description" name="description">
                                <field name="description" placeholder="Add detailed operational notes..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </arch>
        </record>

        <!-- Window Action -->
        <record id="action_business_task" model="ir.actions.act_window">
            <name>Business Tasks</name>
            <res_model>business.task</res_model>
            <view_mode>tree,form</view_mode>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_business_task_root" name="Operations" sequence="10"/>
        <menuitem id="menu_business_task_list" name="Tasks" parent="menu_business_task_root" action="action_business_task" sequence="10"/>

    </data>
</odoo>